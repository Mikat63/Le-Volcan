{% extends 'base.html.twig' %}

{% block title %}Contact
{% endblock %}

{% block body %}

	<main class="w-full flex flex-col flex-1 items-center justify-center gap-12 py-9">
		<div class="w-[90%] h-auto flex flex-col items-center py-9 gap-14">

			<h1 class=" text-8xl font-[lobsterTwo] gold-color-text">Contactez-nous !</h1>


			{{form_start(form, {'attr': {'class': 'flex flex-col items-center justify-center gap-6 text-white text-[inter] text-[28px] border-4 gold-border p-9'}})}}
			<div class="flex flex-row gap-6 w-full justify-between items-center">
				{{ form_label(form.lastname, 'Nom* :') }}
				{{ form_widget(form.lastname, {'attr': {'required': true, 'minlength': 3, 'maxlength': 50, 'placeholder': 'Entrez votre nom', 'class': "text-[16px] bg-white rounded-sm w-64  text-black  p-1 hover:scale-105 focus:scale-105 outline-none cursor-pointer"}})}}
				{{ form_error(form.lastname, {'attr': {'class': "text-[16px] text-white font-semibold"}})}}
			</div>

			<div class="flex flex-row gap-6 w-full justify-between items-center">
				{{ form_label(form.firstname, 'Prénom* :') }}
				{{ form_widget(form.firstname, {'attr': {'required': true, 'minlength': 3, 'maxlength': 50, 'placeholder': 'Entrez votre prénom', 'class': "text-[16px] bg-white rounded-sm w-64  text-black  p-1 hover:scale-1105focus:scale-105 outline-none cursor-pointer"}})}}
				{{ form_error(form.firstname, {'attr': {'class': "text-[16px] text-white font-semibold"}})}}
			</div>

			<div class="flex flex-row gap-6 w-full justify-between items-center">
				{{ form_label(form.email, 'Email* :') }}
				{{ form_widget(form.email, {'attr': {'required': true, 'minlength': 3, 'maxlength': 50, 'placeholder': 'Entrez votre email', 'class': "text-[16px] bg-white rounded-sm w-64  text-black  p-1 hover:scale-105 focus:scale-105 outline-none cursor-pointer"}})}}
				{{ form_error(form.email, {'attr': {'class': "text-[16px] text-white font-semibold"}})}}
			</div>

			<div class="flex flex-row gap-6 w-full justify-between items-center">
				{{ form_label(form.phone, 'Téléphone :') }}
				{{ form_widget(form.phone, {'attr': {'required': true, 'minlength': 3, 'maxlength': 50, 'placeholder': 'Entrez votre téléphone', 'class': "text-[16px] bg-white rounded-sm w-64 text-black  p-1 hover:scale-105 focus:scale-105 outline-none cursor-pointer"}})}}
				{{ form_error(form.phone, {'attr': {'class': "text-[16px] text-white font-semibold"}})}}
			</div>


			<div class="flex flex-col gap-6 w-full ">
				{{ form_label(form.message, 'Message* :') }}
				{{ form_widget(form.message, {'attr': {'required': true, 'minlength': 3, 'maxlength': 50, 'placeholder': 'Entrez votre message (message compris entre 50 et 255 caractères)', 'class': "text-[16px] w-full h-[300px] bg-white rounded-sm w-64  text-black text-center p-1 hover:scale-105 focus:scale-105 outline-none cursor-pointer"}})}}
				{{ form_error(form.message, {'attr': {'class': "text-[16px] text-white font-semibold"}})}}
			</div>

			<button class='text-white gold-bg text-[20px] w-32 h-10 rouded-sm' type="submit">Envoyer</button>

			{{ form_end(form) }}

		</div>
	</main>
{% endblock %}
